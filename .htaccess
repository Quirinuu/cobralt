# ═══════════════════════════════════════════════════════════
#  /.htaccess — Raiz do projeto CoBraLT
# ═══════════════════════════════════════════════════════════

Options -Indexes

# Força HTTPS (descomente após ter o SSL ativo na Hostinger)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

AddType text/css .css
AddType application/javascript .js
AddType text/html .html

# Força charset UTF-8 nos assets
AddCharset UTF-8 .css .js .html

# Cabeçalhos de segurança globais
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ─── CACHE — CSS e JS sempre revalidam no servidor ────────
# O browser pergunta "mudou?" a cada visita.
# Se não mudou: servidor responde 304 (rápido, sem baixar).
# Se mudou: servidor manda o arquivo novo automaticamente.
# Resultado: visitante SEMPRE vê a versão mais recente,
# sem precisar de ?v= manual ou limpar cache.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header unset ETag
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    # CSS e JS: sem cache longo — controlado pelo must-revalidate acima
    ExpiresByType text/css                "access plus 0 seconds"
    ExpiresByType application/javascript  "access plus 0 seconds"
    ExpiresByType text/html               "access plus 0 seconds"
    # Imagens e fontes: cache longo (raramente mudam)
    ExpiresByType image/png               "access plus 6 months"
    ExpiresByType image/jpg               "access plus 6 months"
    ExpiresByType image/jpeg              "access plus 6 months"
    ExpiresByType image/webp              "access plus 6 months"
    ExpiresByType image/svg+xml           "access plus 6 months"
    ExpiresByType font/woff2              "access plus 1 year"
</IfModule>

# ETag habilitado para comparação de versão
FileETag MTime Size

# Compressão gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Bloqueia acesso a arquivos sensíveis
<FilesMatch "\.(sql|log|env|sh|json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloqueia acesso a arquivos ocultos
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Erros customizados
# ErrorDocument 404 /pages/404.html
# ErrorDocument 500 /pages/500.html
